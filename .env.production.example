# JM Baryani HQ - Production Environment
# Copy this to .env.production and fill in your values
# The deploy.sh script will auto-generate this with random passwords

# Database
POSTGRES_USER=jmbariani
POSTGRES_PASSWORD=CHANGE_ME_RANDOM_PASSWORD
POSTGRES_DB=jmbariani
DATABASE_URL=postgresql://jmbariani:CHANGE_ME_RANDOM_PASSWORD@db:5432/jmbariani

# App Security
SECRET_KEY=CHANGE_ME_RANDOM_SECRET_KEY
DEBUG=false

# File Uploads
UPLOAD_DIR=/app/uploads

# OCR
OCR_LANG=eng
TESSDATA_PREFIX=/usr/share/tesseract-ocr/5/tessdata
